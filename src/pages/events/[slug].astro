---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";
//@ts-nocheck

export async function getStaticPaths() {
  const options = {
    headers: {
      apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1senlhbnRteHNxbndudnl0Ym91Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY2MTAwMDEsImV4cCI6MjA5MjE4NjAwMX0.4oMNQybK4PWOr2cjGryFGCCp91oxjC7TSW1qGnPpwbo",
    },
  };

  const url = "https://mlzyantmxsqnwnvytbou.supabase.co/rest/v1/tema9";

  // Hent alle events til at generere sider
  const res = await fetch(url, options);
  const data = await res.json();

  return data.map((post) => {
    return {
      params: { slug: post.slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;

// Fetch bottom events (ID 1 og 2)
const options = {
  headers: {
    apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1senlhbnRteHNxbndudnl0Ym91Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY2MTAwMDEsImV4cCI6MjA5MjE4NjAwMX0.4oMNQybK4PWOr2cjGryFGCCp91oxjC7TSW1qGnPpwbo",
  },
};

const url = "https://mlzyantmxsqnwnvytbou.supabase.co/rest/v1/tema9";

const resBottom = await fetch(url + "?id=in.(3,4)", options);
const bottomEvents = await resBottom.json();
---

<Layout>
  <section class="hero">
    <h1>Foredrag med Lise Grønberg</h1>
    <p class="ordpodod">{post.dato}</p>
    <div class="btn-wrapper">
      <a href="/events" class="btn">Andre events</a>
    </div>
  </section>

  <title class="kolon">{post.beskrivelse}</title>

  <h2 class="tekst">{post.id}: {post.beskrivelse}</h2>

  <section class="section1">
    <h2 class="omevent">OM EVENTET</h2>
    <div class="del1">
      <p class="omeventtext">
        Lise er specialist i sorgterapi og har gennem mange år arbejdet med mennesker, der står midt i livets sværeste øjeblikke. I sit foredrag sætter Lise fokus på, hvordan sorgen ikke er noget, der skal “overstås”, men noget der skal have plads.
        Hun deler ærligt ud af sine erfaringer fra mødet med mennesker i sorg og giver konkrete perspektiver på, hvordan man kan leve med sorgen som en del af livet - uden at lade den definere det hele.
      </p>

      <img class="img1" src={post.image} alt="" />
      <p></p>
      <p class="date">{post.dato}</p>
      <a href="" class="btn2">Tilmeld dig her</a>
    </div>
  </section>

  <section class="section2">
    <h2 class="h22">TÆTTERE PÅ LISE</h2>
    <div class="del2">
      <p class="p2">
        Lisa har mange års erfaring inden for sorgterapi og har arbejdet med både individuelle forløb og grupper i forskellige livssituationer. Gennem sit arbejde har hun mødt mennesker i alle aldre og med vidt forskellige former for tab, hvilket har
        givet hende en bred og nuanceret forståelse af sorgens mange udtryk. Hun har løbende videreuddannet sig og kombinerer faglig viden med praktisk erfaring. Lisas tilgang er præget af ro, empati og respekt for den enkeltes proces, og hun er
        kendt for at skabe et trygt og tillidsfuldt rum.
      </p>
      <div>
        <img class="img2" src="/image/billede2.png" alt="beskrivelse" />
        <p class="fototekst">Lise Grønborg - Specialist i sorgterapi</p>
      </div>
    </div>
  </section>

  <section class="andre-events">
    <h2>SE VORES ANDRE EVENTS</h2>

    <div class="bottom-grid">
      {bottomEvents.map((event) => <Card event={event} />)}
    </div>
  </section>
</Layout>

<style>
  h1 {
    font-family: "Bodoni 72", serif;
    font-weight: 400;
    font-size: 60px;
    text-align: center;
  }

  h2 {
    font-family: "Bodoni 72", serif;
    font-weight: 400;
  }

  p {
    font-family: "Gilda Display", serif;
    font-size: 18px;
    font-weight: 400;
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: #f99173;
    color: white;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 1rem;
  }
  .btn2 {
    padding: 0.5rem 1rem;
    background-color: #f99173;
    color: black;
    border-radius: 2em;
    text-decoration: none;
    grid-column: 2;
    justify-self: end;
    width: fit-content;
    margin-right: 4em;
    margin-bottom: 2em;
  }

  .hero {
    background: #e6d7cf;
    text-align: center;
    padding: 5rem 1rem;
  }

  .andre-events {
    margin-top: 4rem;
    padding: 2rem;
  }

  .andre-events h2 {
    text-align: center;
    margin-bottom: 2em;
  }
  .bottom-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    justify-items: center;
  }

  .date {
    opacity: 0.5;
    margin-left: 5em;
  }
  .del1 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .section1 {
    background-color: rgba(162, 139, 130, 0.15);
    padding: 2em;
    margin: 3em auto;
    max-width: 1300px;
  }

  .omeventtext {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0em 3em 0em 3em;
  }

  .omevent {
    margin-left: 2.2em;
  }
  p {
    line-height: 1.6;
  }
  .tekst {
    margin-top: 4em;
  }

  .img1 {
    justify-self: center;
  }

  .del2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-left: 3em;
  }

  .p2 {
    background-color: rgba(162, 139, 130, 0.15);
    padding: 2em;
    width: 650px;
    height: 400px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 auto;
  }
  .img2 {
    width: 260px;
    height: 350px;
    margin-left: 5em;
  }
  .h22 {
    text-align: center;
    margin-top: 3em;
    margin-bottom: 2em;
  }
  .fototekst {
    margin-left: 5.6em;
    font-size: 14px;
    opacity: 0.7;
    margin-top: 0.5em;
  }
  .btn3 {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: #f99173;
    color: white;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 1rem;
  }
  h3 {
    font-weight: 400;
  }
  /* GENERELT */
  body {
    overflow-x: hidden;
    background-image: url("/image/cirekl.svg");
    background-repeat: no-repeat;
    background-size: 1800px;
    background-position: 120% 700px;
  }

  /* HERO – 3 cirkler + roser */
  .hero {
    position: relative;
    text-align: center;
    padding: 8rem 1rem;

    background: linear-gradient(to bottom, #ffc0ac 1%, #a28b82 100%), url("/image/cirekl.svg"), url("/image/cirkel1.svg"), url("/image/cirkel2.svg");

    background-repeat: no-repeat, no-repeat, no-repeat, no-repeat;

    background-size:
      cover,
      /* gradient */ 600px,
      /* cirkel 1 */ 200px,
      /* cirkel 2 */ 400px; /* cirkel 3 */

    background-position:
      center,
      /* gradient */ 200px 700px,
      calc(100% + 0px) -10px,
      0% 100px;
  }

  body {
    overflow-x: hidden;
    background-image: url("/image/cirkel3.svg");
    background-repeat: no-repeat;
    background-size: 300px;
    background-position: 0% 1800px;
  }

  /* HERO – roser */
  .hero::before {
    content: "";
    position: absolute;
    top: 1000px;
    left: -250px;
    transform: scaleX(-1);
    width: 700px;
    height: 700px;
    background-image: url("/image/rose.svg");
    background-size: contain;
    background-repeat: no-repeat;
    opacity: 0.5;
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    top: 50px;
    right: -250px;
    width: 620px;
    height: 620px;
    background-image: url("/image/rose.svg");
    background-size: contain;
    background-repeat: no-repeat;
    opacity: 0.8;
    pointer-events: none;
  }

  /* MAIN – 1 stor cirkel bag hele indholdet */
  .section1,
  .section2,
  .section3 {
    position: relative;
    overflow: visible;
    background-repeat: no-repeat;
    background-size: 1800px;
    background-position: 100% 100px;
  }

  /* ROSER LÆNGERE NEDE */
  .section1::after {
    content: "";
    position: absolute;
    mask-image: url("/image/rose.svg");
    mask-size: contain;
    mask-repeat: no-repeat;
    opacity: 0.2;
    width: 900px;
    height: 1100px;
    top: 700px;
    right: -500px;
    transform: rotate(-15deg);
    background-color: #f76237;
    pointer-events: none;
  }

  .section3::before {
    content: "";
    position: absolute;
    background-image: url("/image/rose.svg");
    background-size: contain;
    background-repeat: no-repeat;
    opacity: 0.2;
    width: 800px;
    height: 900px;
    top: -250px;
    left: -320px;
    transform: scaleX(-1);
    pointer-events: none;
  }
  @media (max-width: 768px) {
    /* Alt i én kolonne */
    .del1,
    .del2,
    .bottom-grid {
      grid-template-columns: 1fr;
      margin-left: 0;
    }

    .section1 {
      margin: 2em 1em;
      padding: 1.5em;
    }

    .omeventtext,
    .p2 {
      padding: 1.5em;
      width: 100%;
      height: auto;
      margin: 0;
    }

    .img1 {
      width: 100%;
      height: auto;
      margin: 1em auto 0 auto;
    }

    .img2 {
      width: 200px;
      height: auto;
      justify-self: center;
      margin-top: 2em;
    }
    .fototekst {
      margin-left: 1em;
      margin-left: 5.5em;
    }

    .date {
      margin-left: 0;
      justify-self: start;
    }

    .btn2 {
      grid-column: 1;
      justify-self: start;
      margin-right: 0;
      margin-left: 0;
    }

    .andre-events {
      padding: 1.5rem 1rem;
    }
  }
</style>
