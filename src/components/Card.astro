---
//@ts-nocheck
const { event } = Astro.props;
---

<a href={"/events/" + event.slug} class="card">
  <img src={event.image} alt="" />

  <div class="content">
    <p class="date">{event.dato}</p>
    <p>{event.beskrivelse}</p>
    <span class="btn">{event.cta}</span>
  </div>
</a>

<style>
  .card {
    display: block;
    background: #f4eee9;
    padding: 2em;
    overflow: hidden;
    text-decoration: none;
    color: black;
    width: 400px;
    margin: 0 auto;
  }

  .card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }

  .content {
    margin-top: 1em;
  }
  .date {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .btn {
    display: inline-block;
    margin-top: 0.5rem;
    background: #ef8f6b;
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
  }
</style>
